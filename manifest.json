{
  "manifest_version": 3,
  "name": "Gemini Auto Temp Chat",
  "version": "1.0",
  "description": "Automatically enables Temporary Chat on gemini.google.com",
  "permissions": ["storage"],
  "action": { "default_popup": "popup.html" },
  "content_scripts": [{
    "matches": ["https://gemini.google.com/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }]
}
